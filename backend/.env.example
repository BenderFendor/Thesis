# Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Backend Configuration
PORT=8000
HOST=0.0.0.0

# LLM Backend Selection
# "openrouter" (default) — uses OpenRouter cloud API
# "llamacpp"             — uses a local llama.cpp server (no API key needed)
LLM_BACKEND=openrouter

# OpenRouter Configuration (used when LLM_BACKEND=openrouter)
OPEN_ROUTER_API_KEY=your_openrouter_key
OPEN_ROUTER_MODEL=z-ai/glm-4.5-air:free

# llama.cpp local server (used when LLM_BACKEND=llamacpp)
# Start the server with: llama-server -m /path/to/model.gguf --host 127.0.0.1 --port 8080
# The model name below is sent in API requests but ignored by llama.cpp — any value works.
# LLAMACPP_BASE_URL=http://localhost:8080/v1
# LLAMACPP_MODEL=local
# LLAMACPP_API_KEY=no-key

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CORS_ORIGIN_REGEX='^https?://(localhost|127\.0\.0\.1|10\.[0-9.]+|172\.(1[6-9]|2[0-9]|3[0-1])\.[0-9.]+|192\.168\.[0-9.]+)(:[0-9]+)?$|^https://([a-z0-9-]+\.)?jordandgreen\.com$'

# Feature flags
ENABLE_DATABASE=1
ENABLE_INCREMENTAL_CACHE=1
