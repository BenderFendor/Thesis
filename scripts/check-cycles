#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

echo "== Dependency cycle check =="
echo "--- Frontend (madge) ---"
frontend_cycles="$(cd frontend && npx --yes madge --circular --json --no-spinner --extensions ts,tsx --ts-config tsconfig.json app components hooks lib)"
frontend_cycle_count="$(printf '%s' "$frontend_cycles" | python -c 'import json,sys; print(len(json.load(sys.stdin)))')"
echo "Frontend cycles: $frontend_cycle_count"
if [[ "$frontend_cycle_count" -gt 0 ]]; then
	printf '%s\n' "$frontend_cycles" | python -c 'import json,sys; [print("- " + " -> ".join(cycle + [cycle[0]])) for cycle in json.load(sys.stdin)]'
	exit 1
fi

echo "--- Backend (import graph) ---"
python backend/scripts/check_import_cycles.py --source backend/app --package-root backend

echo "No dependency cycles detected."
