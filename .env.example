# Jira Cloud credentials
JIRA_URL=https://<your-subdomain>.atlassian.net
JIRA_EMAIL=your.email@domain.com
JIRA_API_TOKEN=<your-api-token>

# Public frontend API fallback used by the browser when a build still points at localhost
NEXT_PUBLIC_PUBLIC_API_URL=https://api.example.com
NEXT_PUBLIC_FRONTEND_HOST_SUFFIX=example.com
